{
  "name": "yscope-docs-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "next-sitemap --config next-sitemap.config.js && npm run copy-sitemap",
    "copy-sitemap": "cp -r public/sitemap*.xml public/robots.txt out/",
    "start": "next start",
    "lint": "npm run lint:check",
    "lint:check": "npm-run-all --sequential --continue-on-error lint:check:*",
    "lint:check:css": "stylelint app/**/*.scss app/**/*.css --allow-empty-input",
    "lint:check:js": "eslint app --max-warnings 0",
    "lint:fix": "npm-run-all --parallel --continue-on-error \"lint:check:* -- --fix\""
  },
  "dependencies": {
    "@next/third-parties": "^16.0.7",
    "bootstrap-icons": "^1.13.1",
    "next": "^16.0.7",
    "next-sitemap": "^4.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.34.0",
    "bootstrap": "^5.3.6",
    "eslint-config-next": "^15.3.3",
    "eslint-config-yscope": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.89.2",
    "stylelint": "^16.20.0",
    "stylelint-config-clean-order": "^6.1.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "5.7.3"
  }
}
